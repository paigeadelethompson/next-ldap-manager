# Netcrave Certificate Schema Definition
# This schema defines LDAP object classes for PKI certificate management

attributetype ( 1.3.6.1.4.1.37476.2.6.1.1
    NAME 'certificateSerialNumber'
    DESC 'Certificate serial number in hex format'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.2
    NAME 'certificateSubjectCN'
    DESC 'Common Name from certificate subject'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.3
    NAME 'certificateIssuerCN'
    DESC 'Common Name of certificate issuer'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.4
    NAME 'certificateStatus'
    DESC 'Certificate status (valid, revoked, expired, cancelled)'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.5
    NAME 'certificateNotBefore'
    DESC 'Certificate validity start time'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.24
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.6
    NAME 'certificateNotAfter'
    DESC 'Certificate validity end time'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.24
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.7
    NAME 'certificateTemplate'
    DESC 'Certificate template name used to issue this certificate'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.8
    NAME 'certificateProfile'
    DESC 'Certificate profile name used to issue this certificate'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.9
    NAME 'certificateAuthPrincipal'
    DESC 'Kerberos principal that authorized the certificate request'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.10
    NAME 'certificateRevokedAt'
    DESC 'Time when certificate was revoked'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.24
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.11
    NAME 'certificateRevocationReason'
    DESC 'Reason for certificate revocation'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.12
    NAME 'certificateStoragePath'
    DESC 'Path to certificate storage (external system)'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.13
    NAME 'certificatePrivateKeyPath'
    DESC 'Path to private key storage (external system)'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.14
    NAME 'acmeOrderID'
    DESC 'ACME order ID associated with this certificate'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.15
    NAME 'certificateAutoRenewalDays'
    DESC 'Days before expiration to trigger renewal notification'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.27
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.16
    NAME 'certificateRequireKerberos'
    DESC 'Whether Kerberos authentication is required for ACME access'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.7
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.17
    NAME 'certificateAllowedPrincipals'
    DESC 'List of allowed Kerberos principals for ACME access'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    MULTI-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.18
    NAME 'certificateValidityDays'
    DESC 'Default validity period for certificates from this template'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.27
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.19
    NAME 'certificateKeySize'
    DESC 'Default RSA key size for certificates from this template'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.27
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.20
    NAME 'certificateSANPattern'
    DESC 'Pattern for Subject Alternative Names'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.21
    NAME 'certificateHostnames'
    DESC 'List of hostnames covered by this certificate profile'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
    MULTI-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.22
    NAME 'certificateTemplateEnabled'
    DESC 'Whether this template is enabled for new certificate issuance'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.7
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.23
    NAME 'certificateUsageServerAuth'
    DESC 'Certificate can be used for TLS server authentication'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.7
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.24
    NAME 'certificateUsageClientAuth'
    DESC 'Certificate can be used for TLS client authentication'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.7
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.25
    NAME 'certificateUsageEmailProtection'
    DESC 'Certificate can be used for email protection'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.7
    SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.37476.2.6.1.26
    NAME 'certificateUsageCodeSigning'
    DESC 'Certificate can be used for code signing'
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.7
    SINGLE-VALUE )

objectclass ( 1.3.6.1.4.1.37476.2.6.2.1
    NAME 'certificateTemplate'
    DESC 'Certificate template for defining certificate properties'
    SUP top
    STRUCTURAL
    MUST ( cn )
    MAY ( description $
          certificateValidityDays $
          certificateKeySize $
          certificateSANPattern $
          certificateUsageServerAuth $
          certificateUsageClientAuth $
          certificateUsageEmailProtection $
          certificateUsageCodeSigning $

objectclass ( 1.3.6.1.4.1.37476.2.6.2.2
    NAME 'certificateProfile'
    DESC 'Certificate profile that maps hostnames to templates for ACME'
    SUP top
    STRUCTURAL
    MUST ( cn )
    MAY ( description $
          certificateTemplate $
          certificateHostnames $
          certificateRequireKerberos $
          certificateAllowedPrincipals $
          certificateAutoRenewalDays $

objectclass ( 1.3.6.1.4.1.37476.2.6.2.3
    NAME 'certificateRecord'
    DESC 'Certificate record storing metadata about issued certificates'
    SUP top
    STRUCTURAL
    MUST ( cn $ certificateSerialNumber )
    MAY ( certificateSubjectCN $
          certificateIssuerCN $
          certificateStatus $
          certificateNotBefore $
          certificateNotAfter $
          certificateTemplate $
          certificateProfile $
          certificateAuthPrincipal $
          certificateRevokedAt $
          certificateRevocationReason $
          certificateStoragePath $
          certificatePrivateKeyPath $
          acmeOrderID $

objectclass ( 1.3.6.1.4.1.37476.2.6.2.4
    NAME 'certificateAuthority'
    DESC 'Certificate Authority configuration'
    SUP top
    STRUCTURAL
    MUST ( cn )
    MAY ( description $
          certificateNotAfter $
